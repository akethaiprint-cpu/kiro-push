# Postgres connection string (production) — เช่นจาก Neon
# รูปแบบ: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Token ผู้ดูแลสำหรับ endpoint เขียนราคา (ต้องตั้งค่าเพื่อเปิดการเขียน; ไม่ตั้ง = ปฏิเสธทุกคำขอเขียน)
ADMIN_API_TOKEN=""
