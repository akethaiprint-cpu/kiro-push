# Postgres connection string (production) — เช่นจาก Neon
# รูปแบบ: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Token สำหรับเรียก API เขียนราคาแบบ automation (Bearer) และเป็นค่า fallback ของรหัส login/สร้าง session
# ไม่ตั้งค่า = ปฏิเสธทุกคำขอเขียน (fail-closed)
ADMIN_API_TOKEN=""

# (ตัวเลือก) รหัสผ่านสำหรับ login หน้า /admin — ถ้าไม่ตั้ง จะใช้ค่า ADMIN_API_TOKEN แทน
ADMIN_PASSWORD=""

# (ตัวเลือก) กุญแจเซ็น session cookie — ถ้าไม่ตั้ง จะใช้ค่า ADMIN_API_TOKEN แทน
SESSION_SECRET=""
